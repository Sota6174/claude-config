# シェルスクリプトは常に LF で展開する。
# Windows (core.autocrlf=true) で CRLF 化されるとシェバングが "bash\r" になり、
# Git Bash での実行が壊れるため eol=lf を強制する。macOS 側は元から LF なので無害。
*.sh text eol=lf

# PowerShell スクリプトも LF に統一する。
# PowerShell Core は Windows/mac いずれも LF を問題なく実行でき、
# working copy が両環境で一致するため diff/blame が安定する。
*.ps1 text eol=lf
