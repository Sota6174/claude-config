{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Read",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(wc *)",
      "Bash(wc)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(Measure-Object *)",
      "Bash(Measure-Object)",
      "Bash(Get-Command *)",
      "Bash(gcm *)",
      "Bash(Get-Date *)",
      "Bash(Get-Date)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.env.staging)",
      "Read(**/.envrc)",
      "Read(**/.env.sentry-build-plugin)",
      "Read(**/.sentryclirc)",
      "Read(**/cookies.txt)",
      "Read(**/secrets/**)",
      "Read(**/credentials.md)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.netrc)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh \"Claude Code\" \"確認待ち — 許可を求めています\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh \"Claude Code\" \"完了 — タスクが終了しました\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  },
  "language": "日本語",
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "stable",
  "cleanupPeriodDays": 7,
  "voice": {
    "enabled": false,
    "mode": "hold"
  },
  "skipWorkflowUsageWarning": true,
  "autoCompactEnabled": true,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "model": "sonnet"
}
